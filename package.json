{
  "name": "weibo-comment-viewer",
  "private": true,
  "version": "0.1.0",
  "description": "A viewer for Weibo comments built with Electron and React",
  "author": "Your Name <your.email@example.com>",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"electron .\"",
    "build": "vite build && electron-builder",
    "start": "electron ."
  },
  "build": {
    "appId": "com.yourname.weiboviewer",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "scraper/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "axios": "^1.13.5",
    "electron-store": "^11.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "openai": "^6.22.0",
    "puppeteer": "^24.37.5",
    "random-useragent": "^0.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1"
  }
}
